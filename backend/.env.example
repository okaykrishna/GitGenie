# Server
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# GitHub - create a "classic" personal access token with no special scopes
# (just raises your rate limit from 60/hr to 5000/hr). Public data only.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
